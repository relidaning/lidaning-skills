#!/usr/bin/env bash
set -euo pipefail

SKILLS_DIR="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
REGISTRY="$SKILLS_DIR/registry.yaml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

skill_names() {
  awk '/^  - name:/ {print $3}' "$REGISTRY"
}

skill_path() {
  local name="$1"
  awk -v n="$name" '
    $0 ~ "^  - name: "n"$" {found=1; next}
    found && /path:/ {sub(".*path: *",""); print; exit}
  ' "$REGISTRY"
}

skill_dir() {
  echo "$SKILLS_DIR/$(skill_path "$1")"
}

skill_scope() {
  local dir="$1"
  awk '/^scope:/ {print $2}' "$dir/metadata.yaml"
}

skill_desc() {
  local dir="$1"
  awk '/^description:/ {sub("^description: *",""); print; exit}' "$dir/metadata.yaml"
}

installation_scope() {
  local name="$1"
  if [[ -d "$HOME/.claude/skills/$name" ]]; then
    echo "global"
  elif [[ -d "$SKILLS_DIR/.claude/skills/$name" ]]; then
    echo "project"
  else
    echo "none"
  fi
}

# ---------------------------------------------------------------------------
# List (plaintext)
# ---------------------------------------------------------------------------

cmd_list() {
  printf "${CYAN}lidaning-skills${NC}\n\n"
  while IFS= read -r name; do
    local dir
    dir=$(skill_dir "$name")
    local scope
    scope=$(skill_scope "$dir")
    local desc
    desc=$(skill_desc "$dir")
    local installed
    installed=$(installation_scope "$name")
    local marker=""
    case "$installed" in
      global) marker="${GREEN}[global]${NC}" ;;
      project) marker="${YELLOW}[project]${NC}" ;;
      none) marker="${DIM}[not installed]${NC}" ;;
    esac
    printf "  %-22s %-8s %b  %b\n" "$name" "[$scope]" "$marker" "$desc"
  done < <(skill_names)
  echo ""
}

# ---------------------------------------------------------------------------
# Interactive install (gum)
# ---------------------------------------------------------------------------

cmd_add() {
  if ! command -v gum &>/dev/null; then
    echo -e "${YELLOW}gum not found — falling back to plain list.${NC}"
    echo "Install gum for interactive checkboxes: https://github.com/charmbracelet/gum"
    echo ""
    cmd_list
    exit 0
  fi

  local all_skills=()
  local selected=()
  while IFS= read -r name; do
    all_skills+=("$name")
    if [[ "$(installation_scope "$name")" != "none" ]]; then
      selected+=("$name")
    fi
  done < <(skill_names)

  if [[ ${#all_skills[@]} -eq 0 ]]; then
    echo "No skills found in registry."
    exit 1
  fi

  # Build gum args: each --selected is a separate flag
  local gum_args=(choose --no-limit --header="Select skills to add (space=toggle, enter=confirm)" \
    --cursor-prefix="▏" --cursor.foreground="#FF6B6B" \
    --selected-prefix="☑ " --unselected-prefix="☐ ")
  for s in "${selected[@]}"; do
    gum_args+=(--selected="$s")
  done
  for s in "${all_skills[@]}"; do
    gum_args+=("$s")
  done

  local chosen
  chosen=$(printf '%s\n' "${all_skills[@]}" | gum "${gum_args[@]}") || {
    echo "Cancelled."
    exit 0
  }

  if [[ -z "$chosen" ]]; then
    echo "Nothing selected."
    exit 0
  fi

  echo ""
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    local dir scope
    dir=$(skill_dir "$name")
    scope=$(skill_scope "$dir")
    echo -e "${GREEN}[add]${NC} $name ($scope)"
    "$SKILLS_DIR/install.sh" "$name"
  done <<< "$chosen"

  echo ""
  cmd_list
}

# ---------------------------------------------------------------------------
# Interactive uninstall (gum)
# ---------------------------------------------------------------------------

cmd_rm() {
  if ! command -v gum &>/dev/null; then
    echo -e "${RED}Error:${NC} 'gum' is required for interactive rm."
    exit 1
  fi

  local installed_skills=()
  while IFS= read -r name; do
    if [[ "$(installation_scope "$name")" != "none" ]]; then
      installed_skills+=("$name")
    fi
  done < <(skill_names)

  if [[ ${#installed_skills[@]} -eq 0 ]]; then
    echo "No skills are currently installed."
    exit 0
  fi

  local chosen
  chosen=$(printf '%s\n' "${installed_skills[@]}" | gum choose --no-limit \
    --header="Select skills to remove (space=toggle, enter=confirm)" \
    --cursor-prefix="▏" --cursor.foreground="#FF6B6B" \
    --selected-prefix="☑ " --unselected-prefix="☐ ") || {
    echo "Cancelled."
    exit 0
  }

  if [[ -z "$chosen" ]]; then
    echo "Nothing selected."
    exit 0
  fi

  echo ""
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    local dir scope
    dir=$(skill_dir "$name")
    scope=$(skill_scope "$dir")
    echo -e "${YELLOW}[rm]${NC} $name"
    "$SKILLS_DIR/install.sh" --remove "$name"
  done <<< "$chosen"

  echo ""
  cmd_list
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

usage() {
  cat <<EOF
${CYAN}ldn${NC} — lidaning-skills manager

  ${GREEN}ldn${NC}         Interactive checkbox UI to add/remove skills (gum)
  ${GREEN}ldn list${NC}    Plain-text list with install status
  ${GREEN}ldn add${NC}     Same as bare ldn
  ${GREEN}ldn rm${NC}      Remove installed skills (gum)
EOF
  exit 0
}

case "${1:-}" in
  list|ls)     cmd_list ;;
  add|a)       cmd_add ;;
  rm|remove)   cmd_rm ;;
  -h|--help)   usage ;;
  "")          cmd_add ;;  # bare ldn → checkbox UI
  *)           usage ;;
esac
