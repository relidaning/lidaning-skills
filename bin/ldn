#!/usr/bin/env bash
set -euo pipefail

SKILLS_DIR="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
REGISTRY="$SKILLS_DIR/registry.yaml"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

skill_names() {
  awk '/^  - name:/ {print $3}' "$REGISTRY"
}

skill_path() {
  local name="$1"
  awk -v n="$name" '
    $0 ~ "^  - name: "n"$" {found=1; next}
    found && /path:/ {sub(".*path: *",""); print; exit}
  ' "$REGISTRY"
}

skill_dir() {
  echo "$SKILLS_DIR/$(skill_path "$1")"
}

skill_scope() {
  local dir="$1"
  awk '/^scope:/ {print $2}' "$dir/metadata.yaml"
}

skill_desc() {
  local dir="$1"
  awk '/^description:/ {sub("^description: *",""); print; exit}' "$dir/metadata.yaml"
}

installation_scope() {
  local name="$1"
  if [[ -d "$HOME/.claude/skills/$name" ]]; then
    echo "global"
  elif [[ -d "$PWD/.claude/skills/$name" ]]; then
    echo "project"
  else
    echo "none"
  fi
}

# ---------------------------------------------------------------------------
# List (plaintext)
# ---------------------------------------------------------------------------

cmd_list() {
  printf "${CYAN}lidaning-skills${NC}\n\n"
  while IFS= read -r name; do
    local dir scope desc installed marker
    dir=$(skill_dir "$name")
    scope=$(skill_scope "$dir")
    desc=$(skill_desc "$dir")
    installed=$(installation_scope "$name")
    case "$installed" in
    global) marker="${GREEN}[global]${NC}" ;;
    project) marker="${YELLOW}[project]${NC}" ;;
    none) marker="${DIM}[not installed]${NC}" ;;
    esac
    printf "  %-22s %-8s %b  %b\n" "$name" "[$scope]" "$marker" "$desc"
  done < <(skill_names)
  echo ""
}

# ---------------------------------------------------------------------------
# Interactive manage: unified add/remove via single checkbox UI
# ---------------------------------------------------------------------------

cmd_manage() {
  if ! command -v gum &>/dev/null; then
    printf "${YELLOW}gum not found — falling back to plain list.${NC}\n"
    printf "Install gum: https://github.com/charmbracelet/gum\n\n"
    cmd_list
    exit 0
  fi

  local all_skills=()
  local was_installed=()
  local gum_args=(
    choose --no-limit
    --header="Toggle skills to install / remove  (space=toggle  enter=confirm  q=cancel)"
    --cursor-prefix="[ ] "
    --selected-prefix="[x] "
    --unselected-prefix="[ ] "
    --cursor.foreground="#06B6D4"
    --selected.foreground="#06B6D4"
    --header.foreground="#06B6D4"
  )

  while IFS= read -r name; do
    all_skills+=("$name")
    if [[ "$(installation_scope "$name")" != "none" ]]; then
      was_installed+=("$name")
      gum_args+=(--selected="$name")
    fi
  done < <(skill_names)

  if [[ ${#all_skills[@]} -eq 0 ]]; then
    printf "No skills found in registry.\n"
    exit 1
  fi

  local chosen
  chosen=$(printf '%s\n' "${all_skills[@]}" | gum "${gum_args[@]}") || {
    printf "Cancelled.\n"
    exit 0
  }

  # Build lookup of chosen skills
  declare -A chosen_set=()
  while IFS= read -r name; do
    [[ -n "$name" ]] && chosen_set["$name"]=1
  done <<<"$chosen"

  local did_something=false

  # Install newly selected
  for name in "${all_skills[@]}"; do
    if [[ -n "${chosen_set[$name]:-}" && "$(installation_scope "$name")" == "none" ]]; then
      printf "${CYAN}[add]${NC} %s\n" "$name"
      "$SKILLS_DIR/install.sh" "$name"
      did_something=true
    fi
  done

  # Remove newly deselected
  for name in "${was_installed[@]}"; do
    if [[ -z "${chosen_set[$name]:-}" ]]; then
      printf "${YELLOW}[rm]${NC} %s\n" "$name"
      "$SKILLS_DIR/install.sh" --remove "$name"
      did_something=true
    fi
  done

  $did_something || printf "No changes.\n"
  echo ""
  cmd_list
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

usage() {
  printf "${CYAN}ldn${NC} — lidaning-skills manager\n\n"
  printf "  ${CYAN}ldn${NC}       Toggle skills on/off (checkbox UI)\n"
  printf "  ${CYAN}ldn list${NC}  Plain-text list with install status\n"
}

case "${1:-}" in
list | ls) cmd_list ;;
-h | --help) usage ;;
"") cmd_manage ;;
*) usage ;;
esac
